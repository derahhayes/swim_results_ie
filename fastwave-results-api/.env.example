# Pooled connection (PgBouncer) - used by the FastAPI app at runtime.
# Neon EU region. asyncpg driver.
DATABASE_URL=postgresql+asyncpg://user:password@ep-example-pooler.eu-central-1.aws.neon.tech/fastwave?ssl=require

# Direct connection (no pooler) - used only by Alembic migrations.
# Neon EU region. psycopg2 driver.
DATABASE_URL_DIRECT=postgresql+psycopg2://user:password@ep-example.eu-central-1.aws.neon.tech/fastwave?sslmode=require

# Comma-separated list of allowed CORS origins (exact match only).
# Add the eventual Vercel/custom frontend domain here once known.
CORS_ORIGINS=http://localhost:5173

# Regex for CORS origins that can't be listed exactly (Lovable preview
# subdomains change per-project/per-branch). Default matches
# https://<anything>.lovable.app. Leave unset to use that default.
# CORS_ORIGIN_REGEX=^https://[\w-]+\.lovable\.app$

# Directory where uploaded meet files are stored (LocalDirStorage).
# WARNING: on Railway this is ephemeral - see the comment in
# app/ingestion/storage.py and KNOWN_ISSUES.md before relying on it in
# production. Swapped for an S3-compatible backend before Step 5 exposes
# uploads to real users.
STORAGE_DIR=./storage

# development | production. Only gates the /docs toggle right now.
ENVIRONMENT=development

# Whether /docs and /redoc stay reachable in production. /openapi.json
# itself is never gated (Lovable's codegen needs it regardless).
DOCS_PUBLIC=true
