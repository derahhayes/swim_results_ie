# Pooled connection (PgBouncer) - used by the FastAPI app at runtime.
# Neon EU region. asyncpg driver.
DATABASE_URL=postgresql+asyncpg://user:password@ep-example-pooler.eu-central-1.aws.neon.tech/fastwave?ssl=require

# Direct connection (no pooler) - used only by Alembic migrations.
# Neon EU region. psycopg2 driver.
DATABASE_URL_DIRECT=postgresql+psycopg2://user:password@ep-example.eu-central-1.aws.neon.tech/fastwave?sslmode=require

# Comma-separated list of allowed CORS origins (exact match only).
# Add the eventual Vercel/custom frontend domain here once known.
CORS_ORIGINS=http://localhost:5173

# Regex for CORS origins that can't be listed exactly (Lovable preview
# subdomains change per-project/per-branch). Default matches
# https://<anything>.lovable.app. Leave unset to use that default.
# CORS_ORIGIN_REGEX=^https://[\w-]+\.lovable\.app$

# local | r2. r2 is required when ENVIRONMENT=production (the app refuses
# to start otherwise - see KNOWN_ISSUES.md, resolved entry). local uses
# LocalDirStorage (STORAGE_DIR below) and is fine for dev/test.
STORAGE_BACKEND=local

# Directory where uploaded meet files are stored when STORAGE_BACKEND=local.
STORAGE_DIR=./storage

# Only required when STORAGE_BACKEND=r2. Cloudflare R2 (S3-compatible).
# R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxx
# R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# R2_BUCKET=fastwave-uploads

# development | production. Gates /docs visibility and which
# STORAGE_BACKEND is acceptable (see above).
ENVIRONMENT=development

# Whether /docs and /redoc stay reachable in production. /openapi.json
# itself is never gated (Lovable's codegen needs it regardless).
DOCS_PUBLIC=true

# HS256 signing secret for access/refresh JWTs. No default - generate a
# real random value per environment, e.g.: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-to-a-long-random-value

# Access tokens are short-lived; refresh tokens are stored hashed in
# refresh_tokens and can be individually revoked/rotated.
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Comma-separated. On every app startup, any of these emails that already
# have a `users` row get isAdmin=True (idempotent) - the only way to grant
# the first admin, since every admin-granting endpoint itself requires an
# existing admin. Register the account normally first, then set this and
# redeploy.
ADMIN_EMAILS=
